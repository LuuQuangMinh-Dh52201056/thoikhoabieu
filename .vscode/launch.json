{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Web - Chrome",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "program": "lib/main.dart",
      "toolArgs": [
        "--web-port",
        "3000"
      ]
    },
    {
      "name": "Flutter Web - Edge",
      "request": "launch",
      "type": "dart",
      "deviceId": "edge",
      "program": "lib/main.dart",
      "toolArgs": [
        "--web-port",
        "3000"
      ]
    }
  ]
}
